{
  "name": "@enrichlayer/mcp-server",
  "version": "0.2.0",
  "description": "MCP server for Enrich Layer API — 25 tools for company, person, contact, school, job, and search enrichment",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "enrich-layer-mcp": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "start:http": "node build/http-server.js"
  },
  "keywords": [
