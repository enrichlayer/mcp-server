    "model-context-protocol",
    "enrich-layer",
    "enrichment",
    "company-data",
    "person-data",
    "ai-tools"
  ],
  "author": "Michael Salzinger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/enrichlayer/mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/enrichlayer/mcp-server/issues"
  },
  "homepage": "https://github.com/enrichlayer/mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.0",
    "jose": "^6.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "build",
    "manifest.json",
    "README.md",
    "LICENSE"
